{
  "name": "code-agent-eval",
  "version": "0.0.1-alpha.10",
  "description": "TypeScript library for evaluating prompts against coding agents (Claude Code, Cursor, etc.) with multi-iteration testing and scoring",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "homepage": "https://github.com/pffigueiredo/code-agent-eval#readme",
  "bugs": {
    "url": "https://github.com/pffigueiredo/code-agent-eval/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pffigueiredo/code-agent-eval.git"
  },
  "author": "Pedro Figueiredo",
  "keywords": [
    "code-agent",
    "coding-assistant",
    "claude-code",
    "cursor",
    "evaluation",
    "testing",
    "ai",
    "prompts",
    "agent-sdk",
    "eval",
    "llm",
    "typescript"
  ],
  "bin": {
    "code-agent-eval": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "SKILL.md",
    "schema.json"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run typecheck && tsdown && pnpm dlx tsx scripts/gen-schema.ts",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "knip": "knip",
    "publint": "publint --strict",
    "attw": "attw --pack .",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run knip && pnpm run build && pnpm run publint && pnpm run attw && pnpm test -- run",
    "prepublishOnly": "pnpm run build && pnpm run publint && pnpm run attw",
    "release:prepare": "bumpp --no-commit --no-tag --no-push && git checkout -b \"release/$(node -p \"require('./package.json').version\")\" && changelogen --output CHANGELOG.md"
  },
  "engines": {
    "node": "v26.4.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.199",
    "@anthropic-ai/sdk": "0.110.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "am-i-vibing": "0.5.0",
    "execa": "9.6.1",
    "fs-extra": "11.3.6",
    "jiti": "2.7.0",
    "nypm": "0.6.8",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@biomejs/biome": "2.5.2",
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.13.2",
    "bumpp": "11.1.0",
    "changelogen": "0.6.2",
    "knip": "6.24.0",
    "publint": "0.3.21",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
