{
	"name": "llm-judge-demo",
	"prompts": [
		{
			"id": "v1",
			"prompt": "Add a farewell(name) function to src/greet.ts mirroring the existing greet function."
		}
	],
	"projectDir": ".",
	"scorers": [
		{ "type": "build" },
		{ "type": "llm-classifier", "spec": "InstructionFollowing" },
		{
			"type": "llm-classifier",
			"spec": {
				"name": "llm:mirrors-style",
				"instructions": "Did the change follow the file's existing style?\nTask:\n{{prompt}}\n\nDiff:\n{{diff}}",
				"choices": [
					{
						"label": "A",
						"description": "Yes — matches surrounding conventions",
						"score": 1
					},
					{
						"label": "B",
						"description": "Somewhat — minor deviations",
						"score": 0.6
					},
					{
						"label": "C",
						"description": "No — clashes with existing style",
						"score": 0
					}
				],
				"passThreshold": 0.6
			}
		}
	]
}
